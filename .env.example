# ── API (apps/api) ─────────────────────────────────────────────
# Port the Fastify server listens on
API_PORT=3999

# SQLite database file (relative to apps/api, or absolute)
DATABASE_URL=./data/jazz-trainer.sqlite

# Session cookie signing secret (any long random string in dev)
SESSION_SECRET=dev-insecure-change-me

# Dev-login fallback: when true, POST /api/auth/dev-login is enabled
# so the app runs without real Google OAuth credentials.
AUTH_DEV_MODE=true

# Google OAuth (optional; only needed for real Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3999/api/auth/google/callback

# Where the API redirects back to the web app after auth
WEB_ORIGIN=http://localhost:5173

# ── Web (apps/web) ─────────────────────────────────────────────
# Base URL of the API as seen by the browser
VITE_API_BASE_URL=http://localhost:3999
