{
  "name": "jazz-trainer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser-based jazz harmony trainer: harmony grids, precise metronome, DSL, progression generators.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev -w @jazz/web",
    "dev:api": "npm run dev -w @jazz/api",
    "build": "npm run typecheck && npm run build:web && npm run build:api",
    "build:web": "npm run build -w @jazz/web",
    "build:api": "npm run build -w @jazz/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.11"
  }
}
